# Use your Neon connection string (Option B — no Docker needed)
# Example: postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

PORT=3001
NODE_ENV=development

# Required in production — use a long random string (openssl rand -hex 32)
JWT_SECRET=
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3001
